{
  "name": "foodstore-functions",
  "version": "1.0.0",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "build":   "tsc",
    "watch":   "tsc --watch",
    "serve":   "npm run build && firebase emulators:start --only functions",
    "deploy":  "firebase deploy --only functions",
    "lint":    "eslint src --ext ts"
  },
  "engines": { "node": "20" },
  "dependencies": {
    "firebase-admin":    "^12.1.0",
    "firebase-functions": "^4.9.0",
    "mercadopago":       "^2.0.6"
  },
  "devDependencies": {
    "@types/node":        "^20.14.0",
    "typescript":         "^5.4.5"
  }
}
