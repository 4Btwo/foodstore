rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Funções auxiliares ──────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function belongsToRestaurant(restaurantId) {
      return isAuthenticated() && getUserData().restaurantId == restaurantId;
    }

    function isAdminOf(restaurantId) {
      return isAdmin() && belongsToRestaurant(restaurantId);
    }

    // ─── Restaurants ─────────────────────────────────────────────────────────
    match /restaurants/{restaurantId} {
      allow read:  if belongsToRestaurant(restaurantId);
      allow write: if isAdminOf(restaurantId);
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Usuário pode ler seus próprios dados; admin pode ler todos do restaurante
      allow read: if request.auth.uid == userId
                  || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // ─── Products ────────────────────────────────────────────────────────────
    match /products/{productId} {
      allow read:  if belongsToRestaurant(resource.data.restaurantId)
                   || resource.data.active == true; // cardápio público via QR
      allow write: if isAdminOf(resource.data.restaurantId)
                   || (request.resource != null && isAdminOf(request.resource.data.restaurantId));
    }

    // ─── Tables ──────────────────────────────────────────────────────────────
    match /tables/{tableId} {
      allow read:  if belongsToRestaurant(resource.data.restaurantId);
      allow write: if isAuthenticated()
                   && belongsToRestaurant(resource.data.restaurantId);
    }

    // ─── Orders ──────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read:  if belongsToRestaurant(resource.data.restaurantId);
      allow create: if isAuthenticated()
                    && belongsToRestaurant(request.resource.data.restaurantId);
      allow update: if isAuthenticated()
                    && belongsToRestaurant(resource.data.restaurantId);
      allow delete: if isAdminOf(resource.data.restaurantId);
    }

    // ─── Order Items ─────────────────────────────────────────────────────────
    match /order_items/{itemId} {
      allow read, write: if isAuthenticated();
    }

    // ─── Table Calls ─────────────────────────────────────────────────────────
    match /tableCalls/{callId} {
      allow read, write: if isAuthenticated()
                         && belongsToRestaurant(resource.data.restaurantId);
      allow create: if true; // cliente via QR pode chamar garçom
    }
  }
}
