rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Restaurantes: admins e superadmins podem fazer upload
    // Qualquer um pode ler (imagens públicas do cardápio)
    match /restaurants/{restaurantId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024   // máx 5MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Produtos: mesma regra
    match /products/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
